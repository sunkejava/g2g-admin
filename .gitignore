# .gitignore for G2G Admin

# Build outputs
bin/
obj/
*.user
*.suo
*.cache
dist/
*.dll
*.pdb
*.exe
publish/

# Frontend build output (integrated to backend)
G2G.Admin.API/wwwroot/

# Dependencies
node_modules/
packages/

# Logs (backend only)
*.log
G2G.Admin.API/logs/

# Database
*.db
*.db-shm
*.db-wal

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
appsettings.Development.json

# Test scripts
test-*.sh
test-*.txt

# Uploads
uploads/

# Data protection keys
/DataProtection-Keys/
